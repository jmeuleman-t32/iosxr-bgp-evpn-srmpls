{
  "name": "Ansible Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.ansible",
        "redhat.vscode-yaml",
        "ms-python.python"
      ]
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "ansible --version && ansible-lint --version"
}